{
  "models": {
    "claude_sonnet_3_7": {
      "provider": "anthropic",
      "model": "claude-3-7-sonnet-latest",
      "env_key": "ANTHROPIC_API_KEY"
    },
    "deepseek_v3": {
      "provider": "openrouter",
      "model": "deepseek/deepseek-chat",
      "env_key": "OPENROUTER_API_KEY"
    },
    "claude_3_5_sonnet_or": {
      "provider": "openrouter",
      "model": "anthropic/claude-3.5-sonnet",
      "env_key": "OPENROUTER_API_KEY"
    },
    "gpt_4o": {
      "provider": "openai",
      "model": "gpt-4o",
      "env_key": "OPENAI_API_KEY"
    },
    "llama_3_3_groq": {
      "provider": "groq",
      "model": "llama-3.3-70b-versatile",
      "env_key": "GROQ_API_KEY"
    },
    "gemini_1_5_pro": {
      "provider": "google",
      "model": "gemini-1.5-pro",
      "env_key": "GOOGLE_API_KEY"
    },
    "gemini_2_0_flash": {
      "provider": "google",
      "model": "gemini-2.0-flash",
      "env_key": "GOOGLE_API_KEY"
    },
    "deepseek_r1": {
      "provider": "openrouter",
      "model": "deepseek/deepseek-reasoner",
      "env_key": "OPENROUTER_API_KEY"
    }
  },
  "planner": {
    "model": "claude_sonnet_3_7"
  },
  "summary": {
    "model": "gemini_2_0_flash"
  },
  "reconnaissance": {
    "model": "deepseek_v3",
    "nmap": {
      "transport": "stdio",
      "command": "python",
      "args": [
        "mcp_servers/nmap_server.py"
      ],
      "env": {}
    }
  },
  "initial_access": {
    "model": "deepseek_r1",
    "sqlmap": {
      "transport": "stdio",
      "command": "python",
      "args": [
        "mcp_servers/sqlmap_server.py"
      ],
      "env": {}
    },
    "metasploit": {
      "transport": "stdio",
      "command": "python",
      "args": [
        "mcp_servers/metasploit_server.py"
      ],
      "env": {
        "MSF_HOST": "127.0.0.1",
        "MSF_PORT": "55553",
        "MSF_PASS": "decepticon_pass"
      }
    }
  },
  "execution": {
    "model": "claude_sonnet_3_7",
    "metasploit": {
      "transport": "stdio",
      "command": "python",
      "args": [
        "mcp_servers/metasploit_server.py"
      ],
      "env": {
        "MSF_HOST": "127.0.0.1",
        "MSF_PORT": "55553",
        "MSF_PASS": "decepticon_pass"
      }
    }
  },
  "persistence": {
    "model": "deepseek_v3"
  },
  "privilege_escalation": {
    "model": "deepseek_r1",
    "metasploit": {
      "transport": "stdio",
      "command": "python",
      "args": [
        "mcp_servers/metasploit_server.py"
      ],
      "env": {
        "MSF_HOST": "127.0.0.1",
        "MSF_PORT": "55553",
        "MSF_PASS": "decepticon_pass"
      }
    }
  },
  "defense_evasion": {
    "model": "deepseek_v3"
  },
  "researcher": {
    "model": "gemini_2_0_flash",
    "nuclei": {
      "transport": "stdio",
      "command": "python",
      "args": [
        "mcp_servers/nuclei_server.py"
      ],
      "env": {}
    }
  }
}