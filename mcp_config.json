{
  "models": {
    "claude_sonnet_3_7": {
      "provider": "anthropic",
      "model": "claude-3-7-sonnet-latest",
      "env_key": "ANTHROPIC_API_KEY"
    },
    "deepseek_v3": {
      "provider": "openrouter",
      "model": "deepseek/deepseek-chat",
      "env_key": "OPENROUTER_API_KEY"
    },
    "claude_3_5_sonnet_or": {
      "provider": "openrouter",
      "model": "anthropic/claude-3.5-sonnet",
      "env_key": "OPENROUTER_API_KEY"
    },
    "gpt_4o": {
      "provider": "openai",
      "model": "gpt-4o",
      "env_key": "OPENAI_API_KEY"
    }
  },
  "planner": {
    "model": "deepseek_v3"
  },
  "summary": {
    "model": "deepseek_v3"
  },
  "reconnaissance": {
    "model": "deepseek_v3",
    "nmap": {
      "transport": "stdio",
      "command": "python",
      "args": [
        "mcp_servers/nmap_server.py"
      ],
      "env": {}
    }
  },
  "initial_access": {
    "model": "deepseek_v3",
    "sqlmap": {
      "transport": "stdio",
      "command": "python",
      "args": [
        "mcp_servers/sqlmap_server.py"
      ],
      "env": {}
    },
    "metasploit": {
      "transport": "stdio",
      "command": "python",
      "args": [
        "mcp_servers/metasploit_server.py"
      ],
      "env": {
        "MSF_HOST": "127.0.0.1",
        "MSF_PORT": "55553",
        "MSF_PASS": "decepticon_pass"
      }
    }
  },
  "researcher": {
    "model": "deepseek_v3",
    "nuclei": {
      "transport": "stdio",
      "command": "python",
      "args": [
        "mcp_servers/nuclei_server.py"
      ],
      "env": {}
    }
  }
}